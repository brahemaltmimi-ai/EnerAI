# Copy this file to .env and adjust as needed.
# docker compose automatically loads a .env file from the project root.

# Host port for the Nginx-served frontend
FRONTEND_PORT=8080

# Host port for the Flask backend API
BACKEND_PORT=8001

# Host port for the Ollama server
OLLAMA_PORT=11434

# Ollama model used by the AI agent (report generation / rewriting)
OLLAMA_MODEL=llama3.1
